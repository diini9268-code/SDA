generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
}

enum ProgramStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
  CANCELLED
}

enum BlogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ContactMessageStatus {
  UNREAD
  READ
  ARCHIVED
}

enum ContentStatus {
  DRAFT
  PUBLISHED
}

enum SitePage {
  GLOBAL
  HOME
  ABOUT
  BLOG
  MEMBERSHIP
  LEADERSHIP
  CONTACT
}

enum MediaAssetStatus {
  PENDING
  READY
}

enum MediaAssetKind {
  IMAGE
  DOCUMENT
}

model User {
  id           String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fullName     String            @map("full_name") @db.VarChar(160)
  email        String            @unique @db.VarChar(255)
  passwordHash String            @map("password") @db.VarChar(255)
  role         UserRole          @default(ADMIN)
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  mediaAssets  MediaAsset[]      @relation("MediaAssetCreatedBy")
  pageSections PageSection[]     @relation("PageSectionUpdatedBy")
  revisions    ContentRevision[] @relation("ContentRevisionChangedBy")

  @@map("users")
}

model Leadership {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fullName     String      @map("full_name") @db.VarChar(160)
  position     String      @db.VarChar(160)
  biography    String      @db.Text
  photo        String?     @db.VarChar(2048)
  photoAssetId String?     @map("photo_asset_id") @db.Uuid
  displayOrder Int         @default(0) @map("display_order")
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  photoAsset   MediaAsset? @relation("LeadershipPhoto", fields: [photoAssetId], references: [id], onDelete: SetNull)

  @@unique([fullName, position])
  @@map("leadership")
}

model Program {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title        String        @db.VarChar(220)
  slug         String        @unique @db.VarChar(240)
  description  String        @db.Text
  eventDate    DateTime      @map("event_date") @db.Timestamptz(6)
  location     String        @db.VarChar(220)
  status       ProgramStatus @default(DRAFT)
  coverAssetId String?       @map("cover_asset_id") @db.Uuid
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  coverAsset   MediaAsset?   @relation("ProgramCover", fields: [coverAssetId], references: [id], onDelete: SetNull)

  @@index([eventDate])
  @@index([status])
  @@map("programs")
}

model Blog {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String      @db.VarChar(220)
  slug        String      @unique @db.VarChar(240)
  category    String      @db.VarChar(120)
  excerpt     String?     @db.Text
  content     String      @db.Text
  status      BlogStatus  @default(DRAFT)
  publishedAt DateTime    @map("published_at") @db.Timestamptz(6)
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  media       BlogMedia[]

  @@index([category])
  @@index([publishedAt])
  @@index([status])
  @@map("blog")
}

model BlogMedia {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  blogId       String      @map("blog_id") @db.Uuid
  assetId      String?     @map("asset_id") @db.Uuid
  url          String      @db.VarChar(2048)
  altText      String?     @map("alt_text") @db.VarChar(220)
  mimeType     String      @map("mime_type") @db.VarChar(120)
  sizeBytes    Int?        @map("size_bytes")
  displayOrder Int         @default(0) @map("display_order")
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  blog         Blog        @relation(fields: [blogId], references: [id], onDelete: Cascade)
  asset        MediaAsset? @relation("BlogMediaAsset", fields: [assetId], references: [id], onDelete: SetNull)

  @@index([blogId])
  @@map("blog_media")
}

model Archive {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title        String         @db.VarChar(220)
  slug         String         @unique @db.VarChar(240)
  summary      String         @db.Text
  activityDate DateTime       @map("activity_date") @db.Timestamptz(6)
  images       String[]       @default([])
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  media        ArchiveMedia[]

  @@index([activityDate])
  @@map("archive")
}

model MediaAsset {
  id           String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storagePath  String             @unique @map("storage_path") @db.VarChar(1024)
  url          String             @db.VarChar(2048)
  originalName String             @map("original_name") @db.VarChar(255)
  altText      String?            @map("alt_text") @db.VarChar(220)
  mimeType     String             @map("mime_type") @db.VarChar(120)
  sizeBytes    Int                @map("size_bytes")
  kind         MediaAssetKind
  status       MediaAssetStatus   @default(READY)
  createdById  String?            @map("created_by_id") @db.Uuid
  createdAt    DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy    User?              @relation("MediaAssetCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  leadership   Leadership[]       @relation("LeadershipPhoto")
  programs     Program[]          @relation("ProgramCover")
  blogMedia    BlogMedia[]        @relation("BlogMediaAsset")
  archiveMedia ArchiveMedia[]
  sectionMedia PageSectionMedia[]
  partnerLogos Partner[]          @relation("PartnerLogo")

  @@index([kind, status])
  @@index([createdAt])
  @@map("media_assets")
}

model ArchiveMedia {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  archiveId    String     @map("archive_id") @db.Uuid
  assetId      String     @map("asset_id") @db.Uuid
  displayOrder Int        @default(0) @map("display_order")
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  archive      Archive    @relation(fields: [archiveId], references: [id], onDelete: Cascade)
  asset        MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([archiveId, assetId])
  @@index([archiveId, displayOrder])
  @@map("archive_media")
}

model PageSection {
  id           String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  page         SitePage
  key          String             @db.VarChar(120)
  title        String?            @db.VarChar(220)
  content      Json
  status       ContentStatus      @default(PUBLISHED)
  displayOrder Int                @default(0) @map("display_order")
  isVisible    Boolean            @default(true) @map("is_visible")
  updatedById  String?            @map("updated_by_id") @db.Uuid
  createdAt    DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy    User?              @relation("PageSectionUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  media        PageSectionMedia[]

  @@unique([page, key])
  @@index([page, status, isVisible, displayOrder])
  @@map("page_sections")
}

model PageSectionMedia {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sectionId    String      @map("section_id") @db.Uuid
  assetId      String      @map("asset_id") @db.Uuid
  role         String      @default("image") @db.VarChar(80)
  displayOrder Int         @default(0) @map("display_order")
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  section      PageSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  asset        MediaAsset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([sectionId, assetId, role])
  @@index([sectionId, displayOrder])
  @@map("page_section_media")
}

model Partner {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String      @db.VarChar(220)
  website      String?     @db.VarChar(2048)
  logoAssetId  String?     @map("logo_asset_id") @db.Uuid
  displayOrder Int         @default(0) @map("display_order")
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  logoAsset    MediaAsset? @relation("PartnerLogo", fields: [logoAssetId], references: [id], onDelete: SetNull)

  @@unique([name])
  @@index([isActive, displayOrder])
  @@map("partners")
}

model NavigationItem {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  label        String   @db.VarChar(100)
  href         String   @db.VarChar(500)
  location     String   @default("header") @db.VarChar(40)
  displayOrder Int      @default(0) @map("display_order")
  isVisible    Boolean  @default(true) @map("is_visible")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([location, href])
  @@index([location, isVisible, displayOrder])
  @@map("navigation_items")
}

model ContentRevision {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityType  String   @map("entity_type") @db.VarChar(80)
  entityId    String   @map("entity_id") @db.VarChar(120)
  snapshot    Json
  changedById String?  @map("changed_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  changedBy   User?    @relation("ContentRevisionChangedBy", fields: [changedById], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
  @@map("content_revisions")
}

model MembershipApplication {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fullName       String            @map("full_name") @db.VarChar(160)
  email          String            @db.VarChar(255)
  phone          String            @db.VarChar(40)
  university     String            @db.VarChar(180)
  areaOfInterest String            @map("area_of_interest") @db.VarChar(180)
  status         ApplicationStatus @default(PENDING)
  submittedAt    DateTime          @default(now()) @map("submitted_at") @db.Timestamptz(6)
  updatedAt      DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([email])
  @@index([status])
  @@map("membership_applications")
}

model ContactMessage {
  id        String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fullName  String               @map("full_name") @db.VarChar(160)
  email     String               @db.VarChar(255)
  subject   String               @db.VarChar(220)
  message   String               @db.Text
  status    ContactMessageStatus @default(UNREAD)
  createdAt DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([email])
  @@index([status])
  @@map("contact_messages")
}
